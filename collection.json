  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "requests": {},
        "exec": [
          "const LOGIN_REQUEST_NAME = \"Login\";",
          "",
          "if (pm.info.requestName === LOGIN_REQUEST_NAME) return;",
          "",
          "const token = pm.collectionVariables.get(\"authToken\");",
          "",
          "if (!token) {",
          "    console.log(\"🚀 Токен відсутній. Йдемо на логін...\");",
          "    pm.collectionVariables.set(\"postLoginRedirect\", pm.info.requestName);",
          "    pm.execution.setNextRequest(LOGIN_REQUEST_NAME);",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "if (pm.response.code === 200 || pm.response.code === 201) {",
          "    const response = pm.response.json();",
          "",
          "    if (response.data && response.data.id) {",
          "        pm.collectionVariables.set(\"notesId\", response.data.id);",
          "        console.log(\"✅ Новий ID збережено: \" + response.data.id);",
          "    }",
          "}"
        ]
      }
    }
