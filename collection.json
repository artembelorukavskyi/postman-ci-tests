  "item": [
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let token;",
              "",
              "try {",
              "  const json = pm.response.json();",
              "  token = json?.data?.token || json?.token || json?.access_token;",
              "} catch (e) {",
              "  // if response is not JSON, ignore",
              "}",
              "",
              "token = token || pm.response.headers.get(\"x-auth-token\");",
              "",
              "pm.test(\"Login status is 200\", () => {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Token exists\", () => {",
              "  pm.expect(token, \"auth token\").to.be.ok;",
              "});",
              "",
              "pm.collectionVariables.set(\"authToken\", token);",
              "",
              "const redirect = pm.collectionVariables.get(\"postLoginRedirect\");",
              "if (redirect) {",
              "  pm.collectionVariables.unset(\"postLoginRedirect\");",
              "  pm.execution.setNextRequest(redirect);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
